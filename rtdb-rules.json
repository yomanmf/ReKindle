{
    "rules": {
        "freewrite_sessions": {
            "$sessionId": {
                ".read": "auth != null",
                ".write": "auth != null"
            }
        },
        "pro_gate": {
            ".read": "auth != null",
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "presence": {
            ".read": false,
            ".write": false
        },
        "kindlechat": {
            "presence": {
                ".read": false,
                ".write": false
            },
            "messages": {
                ".read": true,
                ".write": "auth.token.email === 'ukiyo@rekindle.ink'",
                ".indexOn": [
                    "timestamp",
                    "user"
                ],
                "$messageId": {
                    ".write": "auth != null && !data.exists() || auth.token.email === 'ukiyo@rekindle.ink'",
                    ".validate": "(newData.hasChildren(['user', 'text', 'timestamp']) && !newData.hasChild('isPro') && !newData.child('user').val().matches(/.*[wW][aA][nN][tT][bB][aA][nN].*/) && ((auth.token.email != null && auth.token.email.beginsWith(newData.child('user').val() + '@')) || (auth.token.email == null && newData.child('user').val() === auth.uid))) || auth.token.email === 'ukiyo@rekindle.ink'",
                    "reactions": {
                        "$uid": {
                            ".write": "auth.uid === $uid",
                            ".validate": "newData.hasChildren(['reaction', 'username'])"
                        }
                    }
                }
            }
        },
        "topics": {
            ".read": "auth != null",
            ".indexOn": [
                "lastActive",
                "timestamp",
                "authorId"
            ],
            "$topicId": {
                ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid || auth.token.email === 'ukiyo@rekindle.ink')",
                ".validate": "newData.hasChildren(['title', 'authorId', 'timestamp'])",
                "authorId": {
                    ".validate": "newData.val() === auth.uid || auth.token.email === 'ukiyo@rekindle.ink'"
                },
                "title": {
                    ".validate": "!data.exists() || newData.val() === data.val() || auth.token.email === 'ukiyo@rekindle.ink'"
                },
                "commentCount": {
                    ".write": "auth != null",
                    ".validate": "newData.isNumber()"
                },
                "lastActive": {
                    ".write": "auth != null",
                    ".validate": "newData.isNumber()"
                }
            }
        },
        "topic_comments": {
            "$topicId": {
                ".read": "auth != null",
                ".indexOn": [
                    "timestamp"
                ],
                "$commentId": {
                    ".write": "auth != null && (!data.exists() || data.child('authorId').val() === auth.uid || auth.token.email === 'ukiyo@rekindle.ink')",
                    ".validate": "newData.hasChildren(['body', 'authorId', 'timestamp']) && (newData.child('authorId').val() === auth.uid || auth.token.email === 'ukiyo@rekindle.ink')"
                }
            }
        },
        "users_public": {
            ".read": "auth != null",
            ".indexOn": ["lastActive", "email"],
            "$userId": {
                ".write": "auth != null && (auth.uid === $userId || auth.token.email === 'ukiyo@rekindle.ink')",
                "username": {
                    ".validate": "auth.token.email === 'ukiyo@rekindle.ink' || (newData.isString() && newData.val().length <= 40 && newData.val().matches(/^[a-zA-Z0-9_.-]+$/) && !newData.val().matches(/.*([uU][kK][iI][yY][oO]|[rR][eE][kK][iI][nN][dD][lL][eE]|[wW][aA][nN][tT][bB][aA][nN]|[rR][oO][oO][tT]|[sS][yY][sS][tT][eE][mM]|[aA][dD][mM][iI][nN]|[mM][oO][dD]|[sS][uU][pP][pP][oO][rR][tT]).*/))"
                }
            }
        },
        "users_private": {
            "$userId": {
                ".read": "auth != null && (auth.uid === $userId || auth.token.email === 'ukiyo@rekindle.ink')",
                ".write": "auth != null && auth.uid === $userId"
            }
        },
        "social_timeouts": {
            ".read": "auth != null",
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "banned_ips": {
            ".read": true,
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "automod_log": {
            ".read": "auth.token.email === 'ukiyo@rekindle.ink'",
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "automod_strikes": {
            ".read": "auth.token.email === 'ukiyo@rekindle.ink'",
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "automod_last_action": {
            ".read": "auth.token.email === 'ukiyo@rekindle.ink'",
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "neighbourhood_posts": {
            ".read": "auth != null",
            ".indexOn": [
                "timestamp",
                "uid"
            ],
            "$postId": {
                "comments": {
                    ".indexOn": [
                        "timestamp"
                    ],
                    "$commentId": {
                        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || auth.token.email === 'ukiyo@rekindle.ink')",
                        ".validate": "newData.hasChildren(['uid', 'text', 'timestamp']) && (newData.child('uid').val() === auth.uid || auth.token.email === 'ukiyo@rekindle.ink')"
                    }
                },
                ".write": "auth != null && ((!data.exists() && newData.child('uid').val() === auth.uid) || (data.exists() && data.child('uid').val() === auth.uid) || auth.token.email === 'ukiyo@rekindle.ink')",
                ".validate": "auth.token.email === 'ukiyo@rekindle.ink' || !newData.exists() || (newData.hasChildren(['uid', 'text', 'timestamp']) && (newData.child('uid').val() === auth.uid || (data.exists() && data.child('uid').val() === newData.child('uid').val() && data.child('text').val() === newData.child('text').val() && data.child('timestamp').val() === newData.child('timestamp').val())))"
            }
        },
        "matchmaking": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "games": {
            ".read": "auth != null",
            ".write": "auth != null"
        }
    }
}