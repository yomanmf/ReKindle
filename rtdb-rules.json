{
    "rules": {
        "freewrite_sessions": {
            "$sessionId": {
                ".read": "auth != null",
                ".write": "auth != null"
            }
        },
        "presence": {
            "$uid": {
                ".read": "auth != null",
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isBoolean()"
            }
        },
        "users_private": {
            "$userId": {
                ".read": "auth != null && (auth.uid === $userId || auth.token.email === 'ukiyo@rekindle.ink')",
                ".write": "auth != null && auth.uid === $userId"
            }
        },
        "banned_ips": {
            ".read": true,
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "matchmaking": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "games": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "suggestions": {
            ".read": true,
            ".indexOn": [
                "createdAt",
                "authorUid",
                "type",
                "status"
            ],
            "$suggestionId": {
                ".write": "auth != null && ((!data.exists() && newData.child('authorUid').val() == auth.uid) || (data.exists() && (auth.token.email == 'ukiyo@rekindle.ink' || auth.token.email.matches(/^.*@rekindle-fork\\.iam\\.gserviceaccount\\.com$/))))",
                ".validate": "newData.hasChildren(['title', 'description', 'authorUid', 'authorName', 'createdAt'])",
                "title": {
                    ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
                },
                "description": {
                    ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
                },
                "type": {
                    ".validate": "newData.isString() && (newData.val() == 'suggestion' || newData.val() == 'problem' || newData.val() == 'translation')"
                },
                "category": {
                    ".validate": "newData.isString() && newData.val().length <= 100"
                },
                "device": {
                    ".validate": "newData.val() == null || (newData.isString() && newData.val().length <= 200)"
                },
                "app": {
                    ".validate": "newData.val() == null || (newData.isString() && newData.val().length <= 200)"
                },
                "authorUid": {
                    ".validate": "newData.isString() && newData.val() == auth.uid"
                },
                "authorName": {
                    ".validate": "newData.isString() && newData.val().length <= 100"
                },
                "isPro": {
                    ".validate": "newData.isBoolean()"
                },
                "status": {
                    ".validate": "newData.val() == null || newData.val() == 'in_progress' || newData.val() == 'done' || newData.val() == 'closed' || newData.val() == 'deferred'"
                },
                "createdAt": {
                    ".validate": "newData.isNumber()"
                },
                "upvotes": {
                    "$uid": {
                        ".write": "auth != null && auth.uid == $uid",
                        ".validate": "newData.val() == true"
                    }
                },
                "comments": {
                    "$commentId": {
                        ".write": "auth != null && ((!data.exists() && newData.child('authorUid').val() == auth.uid && ($commentId == auth.uid + '_1' || $commentId == auth.uid + '_2' || $commentId == auth.uid + '_3')) || (data.exists() && (auth.token.email == 'ukiyo@rekindle.ink' || auth.token.email.matches(/^.*@rekindle-fork\\.iam\\.gserviceaccount\\.com$/))))",
                        ".validate": "newData.hasChildren(['text', 'authorUid', 'createdAt'])",
                        "text": {
                            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 1000"
                        },
                        "authorName": {
                            ".validate": "newData.isString()"
                        },
                        "authorUid": {
                            ".validate": "newData.isString() && newData.val() == auth.uid"
                        },
                        "authorEmail": {
                            ".validate": "newData.isString()"
                        },
                        "isPro": {
                            ".validate": "newData.isBoolean()"
                        },
                        "createdAt": {
                            ".validate": "newData.isNumber()"
                        }
                    }
                }
            }
        },
        "suggestion_reports": {
            ".read": "auth != null && auth.token.email === 'ukiyo@rekindle.ink'",
            ".write": false,
            ".indexOn": [
                "contentId",
                "status",
                "reporterId"
            ]
        },
        "security_actions": {
            ".read": "auth != null && auth.token.email === 'ukiyo@rekindle.ink'",
            ".write": false
        }
    }
}
