{
    "rules": {
        "freewrite_sessions": {
            "$sessionId": {
                ".read": "auth != null",
                ".write": "auth != null"
            }
        },
        "presence": {
            "$uid": {
                ".read": "auth != null",
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isBoolean()"
            }
        },
        "users_private": {
            "$userId": {
                ".read": "auth != null && (auth.uid === $userId || auth.token.email === 'ukiyo@rekindle.ink')",
                ".write": "auth != null && auth.uid === $userId"
            }
        },
        "banned_ips": {
            ".read": true,
            ".write": "auth.token.email === 'ukiyo@rekindle.ink'"
        },
        "matchmaking": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "games": {
            ".read": "auth != null",
            ".write": "auth != null"
        },
        "security_actions": {
            ".read": "auth != null && auth.token.email === 'ukiyo@rekindle.ink'",
            ".write": false
        }
    }
}
