{
    "name": "rekindle-build",
    "version": "1.0.0",
    "scripts": {
        "build": "node build-automation.js",
        "build:badwords": "node scripts/build-bad-words.js",
        "test:chat-ai": "node --test tests/chat-ai-contract.test.js",
        "test:microsoft-todo": "node --test tests/microsoft-todo-contract.test.js",
        "test:social-removal": "node --test tests/social-removal-contract.test.js",
        "test:theme": "node --test tests/theme-contract.test.js",
        "test:telegram": "node --test tests/telegram-client-contract.test.js",
        "deploy:beta": "npx wrangler pages deploy . --project-name=rekindle --branch=beta",
        "deploy:rules:firestore": "firebase deploy --only firestore:rules",
        "deploy:rules:rtdb": "firebase deploy --only database:rules",
        "deploy:rules:storage": "firebase deploy --only storage"
    },
    "dependencies": {
        "@babel/core": "^7.23.0",
        "@babel/preset-env": "^7.23.0",
        "cheerio": "^1.0.0-rc.12",
        "firebase-admin": "^13.7.0",
        "fs-extra": "^11.3.3",
        "glob": "^10.3.0",
        "postcss": "^8.5.10",
        "postcss-preset-env": "^10.5.0",
        "stripe": "^20.3.0"
    },
    "overrides": {
        "fast-xml-parser": "^5.7.0",
        "@tootallnate/once": "^3.0.1"
    },
    "devDependencies": {
        "esbuild": "^0.28.0",
        "obscenity": "^0.4.6"
    }
}
