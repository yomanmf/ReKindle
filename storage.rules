rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
  
    // Direct Firebase Storage is retired. Files and Photo Frame use the Yandex
    // backend, which preserves authentication, ownership, MIME and byte quotas.
    match /users/{userId}/{folder} {
      allow read, write: if false;
      match /{allPaths=**} {
        allow read, write: if false;
      }
    }
    
    // Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
